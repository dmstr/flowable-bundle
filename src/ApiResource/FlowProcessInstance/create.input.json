{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://za7.example.com/schemas/flow-process-instance-create-input.json",
  "title": "flow_process_instance_create input",
  "description": "Input for starting a process instance by definition key or id.",
  "type": "object",
  "anyOf": [
    { "required": ["processDefinitionKey"] },
    { "required": ["processDefinitionId"] }
  ],
  "properties": {
    "processDefinitionKey": {
      "type": "string",
      "description": "Process definition key (latest version is started)."
    },
    "processDefinitionId": {
      "type": "string",
      "description": "Specific process definition id (key:version:deployment)."
    },
    "businessKey": {
      "type": "string",
      "description": "Optional business key for the new process instance."
    },
    "variables": {
      "description": "Process variables: shorthand map {name: value} or explicit list [{name,value,type}].",
      "oneOf": [
        { "type": "object" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": {},
              "type": { "type": "string", "enum": ["string", "integer", "short", "long", "double", "boolean", "date", "json"] }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "apiConfiguration": {
      "description": "Optional Flowable ApiConfiguration selector (full or partial UUID).",
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{8}(-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})?$" },
        { "type": "object", "required": ["uuid"], "properties": { "uuid": { "type": "string" } }, "additionalProperties": false }
      ]
    }
  },
  "additionalProperties": false
}
