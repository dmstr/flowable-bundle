{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://za7.example.com/schemas/flow-execution-trigger-input.json",
  "title": "flow_execution_trigger input",
  "description": "Input for triggering a waiting execution.",
  "type": "object",
  "properties": {
    "variables": {
      "description": "Process variables: shorthand map {name: value} or explicit list [{name,value,type}].",
      "oneOf": [
        { "type": "object" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "value": {},
              "type": { "type": "string", "enum": ["string", "integer", "short", "long", "double", "boolean", "date", "json"] }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    "apiConfiguration": {
      "description": "Optional Flowable ApiConfiguration selector (full or partial UUID).",
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{8}(-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})?$" },
        { "type": "object", "required": ["uuid"], "properties": { "uuid": { "type": "string" } }, "additionalProperties": false }
      ]
    }
  },
  "additionalProperties": false
}
